APP_NAME="Controle de Maquinas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/controle_maquinas

LOG_CHANNEL=stack
LOG_DEPRECATIONS_HELPER=false
LOG_LEVEL=debug

# Configurações do Banco de Dados para o XAMPP
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=controle_maquinas
DB_USERNAME=root
DB_PASSWORD=

# Outras configurações padrão
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120